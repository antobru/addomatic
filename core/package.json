{
  "name": "@addomatic/core",
  "version": "1.0.0",
  "description": "Sistema multi-agente swarm con pipeline sequenziale. Libreria core indipendente.",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/run-swarm.ts",
    "example:ollama": "tsx examples/run-swarm-ollama.ts",
    "example:dev": "tsx examples/run-swarm-dev.ts",
    "example:multi-model": "tsx examples/run-swarm-multi-model.ts",
    "example:pipeline": "tsx examples/run-pipeline-dev.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@makeplane/plane-node-sdk": "^0.2.11"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pdfjs-dist": "^5.6.205",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
