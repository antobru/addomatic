{
  "name": "swarm-agents",
  "version": "1.0.0",
  "description": "Sistema multi-agente swarm in TypeScript: N agenti indipendenti risolvono lo stesso task, poi un aggregatore seleziona o sintetizza la risposta migliore.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/run-swarm.ts",
    "example:ollama": "tsx examples/run-swarm-ollama.ts",
    "example:dev": "tsx examples/run-swarm-dev.ts",
    "example:multi-model": "tsx examples/run-swarm-multi-model.ts",
    "example:pipeline": "tsx examples/run-pipeline-dev.ts",
    "example:pdf-stime": "tsx examples/run-pipeline-pdf-stime.ts",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "npm run dev:server & npm run dev:client",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pdfjs-dist": "^5.6.205",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
