{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "../src/**/*", "../types.ts"],
  "exclude": ["node_modules", "dist", "../node_modules"]
}
